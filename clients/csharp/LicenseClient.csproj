<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net6.0;net7.0;net8.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>

    <PackageId>LicenseClient</PackageId>
    <Version>1.0.0</Version>
    <Authors>Your Company</Authors>
    <Description>License validation client for .NET applications</Description>
    <PackageTags>license;validation;client</PackageTags>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Management" Version="8.0.0" Condition="'$(TargetFramework)' == 'net8.0'" />
    <PackageReference Include="System.Management" Version="7.0.2" Condition="'$(TargetFramework)' == 'net7.0'" />
    <PackageReference Include="System.Management" Version="6.0.2" Condition="'$(TargetFramework)' == 'net6.0'" />
  </ItemGroup>

</Project>
