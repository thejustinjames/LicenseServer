# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/license_server?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Admin credentials (for initial setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_SUCCESS_URL=http://localhost:3000/success
STRIPE_CANCEL_URL=http://localhost:3000/cancel

# =====================================================
# CONFIG PROVIDER
# =====================================================
# Options: env | secrets-manager | kubernetes
CONFIG_PROVIDER=env

# AWS Secrets Manager (if CONFIG_PROVIDER=secrets-manager)
AWS_SECRETS_PREFIX=license-server/
AWS_SECRETS_CACHE_TTL=300

# Kubernetes (if CONFIG_PROVIDER=kubernetes)
K8S_NAMESPACE=default
K8S_CONFIG_PATH=/etc/config
K8S_SECRETS_PATH=/etc/secrets

# =====================================================
# AUTHENTICATION PROVIDER
# =====================================================
# Options: jwt | cognito
AUTH_PROVIDER=jwt

# AWS Cognito (if AUTH_PROVIDER=cognito)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1
COGNITO_ADMIN_GROUP=Admins

# =====================================================
# AWS CONFIGURATION
# =====================================================
AWS_REGION=us-east-1

# AWS Credentials (optional - prefer IAM roles in production)
# Leave these empty to use IAM roles, instance profiles, or IRSA
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS Profile (for local development)
# AWS_PROFILE=default

# Cross-account role (optional)
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/CrossAccountRole

# =====================================================
# AWS S3
# =====================================================
S3_BUCKET_NAME=your-software-bucket

# =====================================================
# CORS CONFIGURATION
# =====================================================
CORS_ENABLED=true
# Comma-separated origins or * for all
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-License-Key
CORS_CREDENTIALS=true
# Preflight cache duration in seconds
CORS_MAX_AGE=86400

# =====================================================
# OFFLINE LICENSE SIGNING
# =====================================================
# RSA keys - generate with:
# openssl genrsa -out keys/private.pem 2048
# openssl rsa -in keys/private.pem -pubout -out keys/public.pem
LICENSE_PRIVATE_KEY_PATH=./keys/private.pem
LICENSE_PUBLIC_KEY_PATH=./keys/public.pem
