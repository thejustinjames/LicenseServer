generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ValidationMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

enum PricingType {
  FIXED
  METERED
}

enum PurchaseType {
  SUBSCRIPTION
  ONE_TIME
}

enum LicenseType {
  INDIVIDUAL    // Single user license
  TEAM          // Team license (5-50 seats)
  ENTERPRISE    // Enterprise/unlimited license
  PLUGIN        // Add-on plugin license
  TRIAL         // Time-limited trial
}

enum LicenseTerm {
  SUBSCRIPTION  // Monthly/Annual recurring
  PERPETUAL     // One-time purchase
  MULTI_YEAR    // 2-3 year terms
}

enum Platform {
  WEB
  WINDOWS
  MACOS
  LINUX
}

model Product {
  id                   String         @id @default(uuid())
  name                 String
  description          String?
  category             String?
  stripeProductId      String?        @unique @map("stripe_product_id")
  stripePriceId        String?        @map("stripe_price_id")
  stripePriceIdAnnual  String?        @map("stripe_price_id_annual")
  priceMonthly         Int?           @map("price_monthly")       // Price in cents
  priceAnnual          Int?           @map("price_annual")        // Price in cents
  validationMode       ValidationMode @default(ONLINE) @map("validation_mode")
  pricingType          PricingType    @default(FIXED) @map("pricing_type")
  purchaseType         PurchaseType   @default(SUBSCRIPTION) @map("purchase_type")
  licenseDurationDays  Int?           @map("license_duration_days")
  s3PackageKey         String?        @map("s3_package_key")
  version              String?
  features             String[]       @default([])
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  // Platform targeting
  platforms            Platform[]     @default([WEB])
  requiresActivation   Boolean        @default(true) @map("requires_activation")

  // Seat configuration for team products
  defaultSeatCount     Int            @default(1) @map("default_seat_count")
  maxSeatCount         Int?           @map("max_seat_count")
  seatPriceMonthly     Int?           @map("seat_price_monthly")    // Per-seat price in cents
  seatPriceAnnual      Int?           @map("seat_price_annual")     // Per-seat price in cents

  // Desktop app configuration
  offlineGraceDays     Int            @default(7) @map("offline_grace_days")
  checkInIntervalDays  Int            @default(7) @map("check_in_interval_days")

  // Product relationships (for plugins/add-ons)
  parentProductId      String?        @map("parent_product_id")
  parentProduct        Product?       @relation("ProductAddons", fields: [parentProductId], references: [id])
  addons               Product[]      @relation("ProductAddons")

  licenses License[]
  quotes   Quote[]

  @@index([category])
  @@index([parentProductId])
  @@map("products")
}

model Customer {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String    @map("password_hash")
  stripeCustomerId    String?   @unique @map("stripe_customer_id")
  name                String?
  isAdmin             Boolean   @default(false) @map("is_admin")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  // Cognito linkage for customers using the external user pool. Nullable so
  // legacy local-password customers continue to work until migrated.
  cognitoSub          String?   @unique @map("cognito_sub")
  cognitoPool         String?   @map("cognito_pool")
  mfaEnabledAt        DateTime? @map("mfa_enabled_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  licenses            License[]
  subscriptions       Subscription[]
  refunds             Refund[]
  passwordResetTokens PasswordResetToken[]
  quotes              Quote[]

  @@map("customers")
}

model License {
  id                 String        @id @default(uuid())
  key                String        @unique
  customerId         String        @map("customer_id")
  productId          String        @map("product_id")
  status             LicenseStatus @default(ACTIVE)
  expiresAt          DateTime?     @map("expires_at")
  lastValidatedAt    DateTime?     @map("last_validated_at")
  machineFingerprint String?       @map("machine_fingerprint")
  maxActivations     Int           @default(1) @map("max_activations")
  metadata           Json?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  // Seat-based licensing
  licenseType        LicenseType   @default(INDIVIDUAL) @map("license_type")
  seatCount          Int           @default(1) @map("seat_count")
  seatsUsed          Int           @default(0) @map("seats_used")

  // Volume/Enterprise licensing
  isVolumeLicense    Boolean       @default(false) @map("is_volume_license")
  volumeDiscount     Decimal?      @db.Decimal(5, 2) @map("volume_discount")

  // License terms
  licenseTerm        LicenseTerm   @default(SUBSCRIPTION) @map("license_term")
  renewalDate        DateTime?     @map("renewal_date")

  // Parent license for seat assignments (organization master license)
  parentLicenseId    String?       @map("parent_license_id")
  parentLicense      License?      @relation("SeatHierarchy", fields: [parentLicenseId], references: [id])
  childLicenses      License[]     @relation("SeatHierarchy")

  customer        Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product         Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  activations     LicenseActivation[]
  seatAssignments SeatAssignment[]

  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([licenseType])
  @@index([parentLicenseId])
  @@map("licenses")
}

model Subscription {
  id                   String             @id @default(uuid())
  customerId           String             @map("customer_id")
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?          @map("current_period_end")
  trialEnd             DateTime?          @map("trial_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  usageRecords UsageRecord[]

  @@index([customerId])
  @@map("subscriptions")
}

model LicenseActivation {
  id                 String   @id @default(uuid())
  licenseId          String   @map("license_id")
  machineFingerprint String   @map("machine_fingerprint")
  machineName        String?  @map("machine_name")
  ipAddress          String?  @map("ip_address")
  activatedAt        DateTime @default(now()) @map("activated_at")
  lastSeenAt         DateTime @default(now()) @map("last_seen_at")

  // Desktop app tracking
  platform           Platform? @map("platform")
  appVersion         String?   @map("app_version")
  osVersion          String?   @map("os_version")

  // Offline token management
  offlineToken       String?   @map("offline_token")
  offlineTokenExpiry DateTime? @map("offline_token_expiry")
  lastCheckIn        DateTime? @map("last_check_in")

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, machineFingerprint])
  @@index([licenseId])
  @@index([platform])
  @@map("license_activations")
}

// Seat assignment for team/enterprise licenses
model SeatAssignment {
  id                 String    @id @default(uuid())
  licenseId          String    @map("license_id")

  // Assigned user
  email              String
  name               String?

  // Assignment tracking
  assignedAt         DateTime  @default(now()) @map("assigned_at")
  assignedBy         String?   @map("assigned_by")

  // Invite tracking
  inviteToken        String?   @unique @map("invite_token")
  inviteSentAt       DateTime? @map("invite_sent_at")
  inviteAcceptedAt   DateTime? @map("invite_accepted_at")

  // Activation tracking
  activated          Boolean   @default(false)
  activatedAt        DateTime? @map("activated_at")
  machineFingerprint String?   @map("machine_fingerprint")
  machineName        String?   @map("machine_name")

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, email])
  @@index([licenseId])
  @@index([email])
  @@index([inviteToken])
  @@map("seat_assignments")
}

// mTLS agent client certificate issuance ledger
// (one row per cert issued by /api/v1/agents/enroll)
model AgentCertificate {
  id                 String    @id @default(uuid())
  licenseId          String    @map("license_id")
  machineFingerprint String    @map("machine_fingerprint")

  serial             String    @unique
  subject            String
  fingerprintSha256  String    @map("fingerprint_sha256")
  notBefore          DateTime  @map("not_before")
  notAfter           DateTime  @map("not_after")

  issuedAt           DateTime  @default(now()) @map("issued_at")
  revokedAt          DateTime? @map("revoked_at")
  revokedReason      String?   @map("revoked_reason")

  // Loose join: do not cascade — keep ledger after license deletion for audit.
  @@index([licenseId])
  @@index([machineFingerprint])
  @@index([revokedAt])
  @@index([notAfter])
  @@map("agent_certificates")
}

// Usage-based billing records
model UsageRecord {
  id                   String   @id @default(uuid())
  subscriptionId       String   @map("subscription_id")
  stripeSubscriptionId String   @map("stripe_subscription_id")
  quantity             Int
  action               String   @default("increment") // increment or set
  timestamp            DateTime @default(now())
  idempotencyKey       String?  @unique @map("idempotency_key")
  stripeUsageRecordId  String?  @map("stripe_usage_record_id")
  metadata             Json?
  createdAt            DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([stripeSubscriptionId])
  @@map("usage_records")
}

// Refund tracking
model Refund {
  id               String   @id @default(uuid())
  stripeRefundId   String   @unique @map("stripe_refund_id")
  stripeChargeId   String   @map("stripe_charge_id")
  customerId       String   @map("customer_id")
  amount           Int      // Amount in cents
  currency         String   @default("usd")
  reason           String?
  status           String   // succeeded, pending, failed, canceled
  licensesRevoked  Boolean  @default(false) @map("licenses_revoked")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("refunds")
}

// Password reset tokens
model PasswordResetToken {
  id         String   @id @default(uuid())
  token      String   @unique
  customerId String   @map("customer_id")
  expiresAt  DateTime @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([token])
  @@map("password_reset_tokens")
}

// Enterprise quotes for POA pricing
model Quote {
  id              String    @id @default(uuid())
  quoteNumber     String    @unique @map("quote_number")
  customerId      String?   @map("customer_id")
  productId       String    @map("product_id")

  // Contact info (for new prospects)
  contactEmail    String    @map("contact_email")
  contactName     String?   @map("contact_name")
  companyName     String?   @map("company_name")

  // Quote details
  seatCount       Int       @map("seat_count")
  term            LicenseTerm @default(SUBSCRIPTION)
  termYears       Int       @default(1) @map("term_years")

  // Pricing
  basePrice       Int       @map("base_price")      // In cents
  discount        Decimal?  @db.Decimal(5, 2)       // e.g., 0.25 = 25% off
  finalPrice      Int       @map("final_price")     // In cents
  currency        String    @default("usd")

  // Custom requirements
  customFeatures  String[]  @default([]) @map("custom_features")
  notes           String?

  // Status
  status          QuoteStatus @default(DRAFT)
  validUntil      DateTime  @map("valid_until")
  acceptedAt      DateTime? @map("accepted_at")
  convertedLicenseId String? @unique @map("converted_license_id")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  customer        Customer? @relation(fields: [customerId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])

  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@map("quotes")
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}
