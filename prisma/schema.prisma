generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ValidationMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

enum PricingType {
  FIXED
  METERED
}

model Product {
  id                   String         @id @default(uuid())
  name                 String
  description          String?
  category             String?
  stripeProductId      String?        @unique @map("stripe_product_id")
  stripePriceId        String?        @map("stripe_price_id")
  validationMode       ValidationMode @default(ONLINE) @map("validation_mode")
  pricingType          PricingType    @default(FIXED) @map("pricing_type")
  licenseDurationDays  Int?           @map("license_duration_days")
  s3PackageKey         String?        @map("s3_package_key")
  version              String?
  features             String[]       @default([])
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  licenses License[]

  @@index([category])
  @@map("products")
}

model Customer {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String   @map("password_hash")
  stripeCustomerId String?  @unique @map("stripe_customer_id")
  name             String?
  isAdmin          Boolean  @default(false) @map("is_admin")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  licenses      License[]
  subscriptions Subscription[]
  refunds       Refund[]

  @@map("customers")
}

model License {
  id                 String        @id @default(uuid())
  key                String        @unique
  customerId         String        @map("customer_id")
  productId          String        @map("product_id")
  status             LicenseStatus @default(ACTIVE)
  expiresAt          DateTime?     @map("expires_at")
  lastValidatedAt    DateTime?     @map("last_validated_at")
  machineFingerprint String?       @map("machine_fingerprint")
  maxActivations     Int           @default(1) @map("max_activations")
  metadata           Json?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  customer    Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  activations LicenseActivation[]

  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@map("licenses")
}

model Subscription {
  id                   String             @id @default(uuid())
  customerId           String             @map("customer_id")
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?          @map("current_period_end")
  trialEnd             DateTime?          @map("trial_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  usageRecords UsageRecord[]

  @@index([customerId])
  @@map("subscriptions")
}

model LicenseActivation {
  id                 String   @id @default(uuid())
  licenseId          String   @map("license_id")
  machineFingerprint String   @map("machine_fingerprint")
  machineName        String?  @map("machine_name")
  ipAddress          String?  @map("ip_address")
  activatedAt        DateTime @default(now()) @map("activated_at")
  lastSeenAt         DateTime @default(now()) @map("last_seen_at")

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, machineFingerprint])
  @@index([licenseId])
  @@map("license_activations")
}

// Usage-based billing records
model UsageRecord {
  id                   String   @id @default(uuid())
  subscriptionId       String   @map("subscription_id")
  stripeSubscriptionId String   @map("stripe_subscription_id")
  quantity             Int
  action               String   @default("increment") // increment or set
  timestamp            DateTime @default(now())
  idempotencyKey       String?  @unique @map("idempotency_key")
  stripeUsageRecordId  String?  @map("stripe_usage_record_id")
  metadata             Json?
  createdAt            DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([stripeSubscriptionId])
  @@map("usage_records")
}

// Refund tracking
model Refund {
  id               String   @id @default(uuid())
  stripeRefundId   String   @unique @map("stripe_refund_id")
  stripeChargeId   String   @map("stripe_charge_id")
  customerId       String   @map("customer_id")
  amount           Int      // Amount in cents
  currency         String   @default("usd")
  reason           String?
  status           String   // succeeded, pending, failed, canceled
  licensesRevoked  Boolean  @default(false) @map("licenses_revoked")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("refunds")
}
